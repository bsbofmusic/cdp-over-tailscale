{
  "name": "cdp-bridge",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "description": "Local CDP bridge for Tailscale-accessible agent browser sessions",
  "author": "bsbofmusic",
  "main": "electron/main.js",
  "bin": {
    "cdp-bridge": "src/cli.js"
  },
  "scripts": {
    "start": "electron .",
    "start:bridge": "node src/cli.js",
    "check": "node --check src/cli.js && node --check src/server.js && node --check src/chrome.js && node --check src/config.js && node --check src/tailscale.js && node --check src/logger.js && node --check src/bridge-service.js && node --check src/supervisor.js && node --check electron/main.js && node --check electron/preload.cjs && node --check electron/renderer.js",
    "pack:win": "electron-builder --dir --win nsis --x64",
    "dist:win": "electron-builder --win nsis --x64"
  },
  "dependencies": {
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "electron": "^35.0.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "ai.cosymart.cdpbridge",
    "productName": "CDP Bridge",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "build/**/*",
      "scripts/**/*",
      "src/**/*",
      "clean-install.cmd",
      "package.json",
      "README.md"
    ],
    "extraMetadata": {
      "main": "electron/main.js"
    },
    "artifactName": "${productName}-Setup-${version}.${ext}",
    "win": {
      "icon": "electron/assets/app-icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "include": "build/installer.nsh",
      "installerIcon": "electron/assets/app-icon.ico",
      "uninstallerIcon": "electron/assets/app-icon.ico",
      "installerHeaderIcon": "electron/assets/app-icon.ico",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "shortcutName": "CDP Bridge",
      "installerLanguages": [
        "en_US",
        "zh_CN"
      ]
    }
  }
}
